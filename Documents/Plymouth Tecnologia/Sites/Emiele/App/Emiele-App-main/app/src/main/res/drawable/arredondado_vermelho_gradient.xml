<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" >
    <item android:state_pressed="true" >
        <shape android:shape="rectangle"  >
            <corners android:radius="20dp" />
            <stroke android:width="0dip" android:color="#FFCC2B46" />
            <gradient android:angle="-270" android:startColor="#72CC2B46" android:endColor="#ffffff"  />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle"  >
            <corners android:radius="20dp" />
            <stroke android:width="0dip" android:color="#FFCC2B46" />
            <solid android:color="#FFCC2B46"/>
        </shape>
    </item>
    <item >
        <shape android:shape="rectangle"  >
            <corners android:radius="20dp" />
            <stroke android:width="0dip" android:color="#FFCC2B46" />
            <gradient android:angle="-270" android:startColor="#ffffff" android:endColor="#31dedede" />
        </shape>
    </item>
</selector>